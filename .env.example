# Copy this to .env and fill in your key (optional — pipeline also works with claude CLI subscription)
ANTHROPIC_API_KEY=sk-ant-...

# Context window tuning — relevant for very long theses
# Rule of thumb: 1 thesis page ≈ 470 tokens (350 words × 1.33 tokens/word)
#   150-page thesis ≈  70k tokens  (well within 200k limit)
#   200-page thesis ≈  94k tokens  (comfortable)
#   300-page thesis ≈ 141k tokens  (fine, leaves room for prompt overhead)
#   400-page thesis ≈ 188k tokens  (close to limit — set MAX_THESIS_PAGES=300 to be safe)
# If you see chapters missing in output/summaries/thesis_analysis.md, reduce this value.
# Default: unlimited (agent ingests the full PDF)
# MAX_THESIS_PAGES=300
